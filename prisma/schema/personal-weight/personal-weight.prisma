model PersonalWeight {
  id Int @id @default(autoincrement())

  visitorId String @map("visitor_id")
  algorithm String // @hactto/algorithm 에 정의된 알고리즘 명
  weights   String // 7개의 가중치 숫자가 담긴 JSON 문자열 (예: "[25,20,15,15,10,10,5]")

  algorithmResults AlgorithmResult[] // 이 가중치 스냅샷으로 예측된 결과 목록

  @@map("personal_weight")
}
