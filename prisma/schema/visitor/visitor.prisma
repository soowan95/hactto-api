model Visitor {
  id String @id
  ip String
  nickname     String?      @unique @db.VarChar(30)
  
  hon          Hon?
  subscription Subscription?
  inquiries    Inquiry[]
  honEvents    HonEvent[]
  block        Block?
  posts        Post[]
  reports      PostReport[]
  postComments PostComment[]
  postLikes    PostLike[]
  commentLikes CommentLike[]
  commentReports CommentReport[]

  @@map("visitor")
}
