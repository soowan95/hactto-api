/**
 * 알고리즘으로 생성된 당첨 번호
 */
model AlgorithmResult {
  id Int @id @default(autoincrement())

  algorithm String // @hactto/algorithm 에 정의된 알고리즘 명
  episode   Int // 로또 회차
  numbers   String // 당첨번호 SET

  ip        String?
  visitorId String? @map("visitor_id")

  winningNumber WinningNumber @relation(fields: [episode], references: [episode])

  reliability Reliability?

  @@map("algorithm_result")
}
