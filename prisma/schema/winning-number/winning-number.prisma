/**
 * 당첨번호
 */
model WinningNumber {
  episode Int @id // 로또 회차

  first  Int // 첫번째 당첨번호
  second Int // 두번째 당첨번호
  third  Int // 세번째 당첨번호
  fourth Int // 네번째 당첨번호
  fifth  Int // 다섯번째 당첨번호
  sixth  Int // 여섯번째 당첨번호
  bonus  Int // 보너스 당첨번호

  reliabilities Reliability[] // 회차 별 각 알고리즘에 대한 신뢰도

  @@map("winning_number")
}
